APP_NAME=PalmOps Web-GIS
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8080
SECRET_KEY=change-this-secret-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

DATABASE_URL=postgresql+psycopg://palmops:palmops@postgres:5432/palmops
REDIS_URL=redis://redis:6379/0

DATA_DIR=/data
MODEL_WEIGHTS_PATH=/models/palm_health.pt
YOLO_CONFIDENCE=0.20
YOLO_IOU=0.45
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=oil-palm-tree-health-detection/1
ROBOFLOW_CONFIDENCE=35
ROBOFLOW_OVERLAP=30
ROBOFLOW_MAX_IMAGE_SIDE=1600
ODM_COMMAND_TEMPLATE=
ODM_TIMEOUT_SECONDS=21600
NODEODM_URL=http://nodeodm:3000
NODEODM_POLL_INTERVAL_SECONDS=10
STITCH_MIN_IMAGES=5
TITILER_BASE_URL=http://titiler:8081
PUBLIC_API_BASE_URL=/api
PUBLIC_TITILER_BASE_URL=/titiler
CLOUDFLARE_TUNNEL_TOKEN=
ALLOWED_ORIGIN_REGEX=^(https://([a-z0-9-]+\.)?apta\.works|http://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+)(:\d+)?)$

DEFAULT_OWNER_EMAIL=owner@example.com
DEFAULT_OWNER_PASSWORD=palmops123
